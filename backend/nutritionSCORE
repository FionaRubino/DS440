/**
 * Calculates a Nutritional Health Score (0-100)
 * @param {Object} data - Object containing calories, protein, fat, and sodium.
 * @returns {Number} - The final calculated NutriScore.
 */
function calculateNutriScore(data) {
    const { calories, protein, fat, sodium } = data;

    // Safety check for empty data
    if (!calories || calories === 0) return 0;

    // 1. Starting Base Score
    let score = 60;

    // 2. Protein Bonus (Goal: High Protein density)
    // Protein has 4 calories per gram.
    const proteinCalories = protein * 4;
    const proteinPercentage = (proteinCalories / calories) * 100;
    
    // Reward: Add 1.5 points for every 1% of protein density
    score += (proteinPercentage * 1.5);

    // 3. Sodium Penalty (Goal: < 1mg per calorie)
    const sodiumDensity = sodium / calories;
    
    // Penalty: Subtract 15 points for every 1mg/cal over the limit
    // If sodium density is 2mg/cal, it subtracts 30 points.
    score -= (sodiumDensity * 15);

    // 4. Fat Penalty (Goal: Avoid excessive calorie density)
    // Fat has 9 calories per gram.
    const fatCalories = fat * 9;
    const fatPercentage = (fatCalories / calories) * 100;

    // Penalty: Subtract 1 point for every 1% over 35% total fat
    if (fatPercentage > 35) {
        score -= (fatPercentage - 35);
    }

    // 5. Final Constraints (Keep score between 0 and 100)
    return Math.min(100, Math.max(0, Math.round(score * 10) / 10));
}

// --- Example Usage with your data ---
const meatloaf = { calories: 1822, protein: 101, fat: 117, sodium: 3523 };
const burrito = { calories: 2667, protein: 101, fat: 170.5, sodium: 2830 };

console.log("Meatloaf Score:", calculateNutriScore(meatloaf)); // Output: ~50.4
console.log("Burrito Score:", calculateNutriScore(burrito));   // Output: ~53.0